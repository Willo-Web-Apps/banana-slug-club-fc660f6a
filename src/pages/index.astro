---
import Base from '../layouts/Base.astro';
---
<Base
  title="Banana Slug Club — Explore Every Animal, Plant & Science Wonder"
  description="From banana slugs to blue whales — discover the amazing natural world through interactive guides, vivid photos, and fun science facts built for kids ages 5–14."
>

  <!-- =====================================================================
       HERO — full-width, layered gradient, nature-forest atmosphere
       ===================================================================== -->
  <section class="relative min-h-[88vh] flex items-center overflow-hidden">

    <!-- Layered CSS background: deep forest atmosphere -->
    <div class="absolute inset-0" style="background:
      radial-gradient(ellipse at 10% 50%, rgba(46,125,50,0.30) 0%, transparent 45%),
      radial-gradient(ellipse at 90% 15%, rgba(27,94,32,0.28) 0%, transparent 50%),
      radial-gradient(ellipse at 60% 95%, rgba(56,142,60,0.22) 0%, transparent 50%),
      radial-gradient(ellipse at 30% 10%, rgba(104,159,56,0.18) 0%, transparent 40%),
      linear-gradient(160deg, #c8e6c9 0%, #a5d6a7 40%, #81c784 100%);
    "></div>

    <!-- Decorative green blobs — leafy depth -->
    <div class="absolute top-10 right-8 md:right-20 w-72 h-72 rounded-full opacity-40 animate-float" style="background: radial-gradient(circle, #2e7d32, transparent 70%);"></div>
    <div class="absolute bottom-16 left-6 w-56 h-56 rounded-full opacity-30 animate-float" style="background: radial-gradient(circle, #1b5e20, transparent 70%); animation-delay: 1.2s;"></div>
    <div class="absolute top-1/2 right-0 w-40 h-40 rounded-full opacity-25 animate-float" style="background: radial-gradient(circle, #388e3c, transparent 70%); animation-delay: 2s;"></div>

    <!-- Decorative nature emojis — large, faded, all green/nature -->
    <div class="absolute top-6 left-4 text-6xl md:text-8xl opacity-10 select-none" aria-hidden="true">🌿</div>
    <div class="absolute top-14 right-12 text-5xl md:text-7xl opacity-10 select-none" aria-hidden="true">🍃</div>
    <div class="absolute bottom-12 right-4 text-6xl md:text-8xl opacity-10 select-none" aria-hidden="true">🌳</div>
    <div class="absolute bottom-6 left-10 text-5xl opacity-10 select-none" aria-hidden="true">🐢</div>
    <div class="absolute top-1/3 left-1/4 text-4xl opacity-8 select-none" aria-hidden="true">🦎</div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-32 text-center">

      <!-- Eyebrow pill -->
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-sm font-semibold mb-6 animate-slide-up" style="background: oklch(0.86 0.22 92 / 0.35); color: oklch(0.32 0.14 92);">
        <span>🐌</span>
        <span>Built by a father &amp; son who love nature</span>
      </div>

      <!-- H1 -->
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-extrabold tracking-tight max-w-4xl mx-auto leading-[1.08] animate-slide-up delay-100" style="color: oklch(0.20 0.016 145); font-family: 'Bricolage Grotesque', sans-serif;">
        Explore Every Animal, Plant,
        <span class="relative inline-block">
          <span class="relative z-10" style="color: oklch(0.52 0.20 145);">and Science Wonder</span>
          <span class="absolute bottom-1 left-0 w-full h-3 rounded-full -z-0 opacity-40" style="background: oklch(0.86 0.22 92);"></span>
        </span>
      </h1>

      <!-- Sub-headline -->
      <p class="mt-6 text-lg md:text-xl max-w-2xl mx-auto leading-relaxed animate-slide-up delay-200" style="color: oklch(0.40 0.018 145);">
        From banana slugs to blue whales — discover the amazing natural world through interactive guides, vivid photos, and fun science facts built for kids.
      </p>

      <!-- CTA buttons -->
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4 animate-slide-up delay-300">
        <a
          href="#explore"
          class="inline-flex items-center gap-2 px-8 py-4 rounded-xl font-bold text-base text-white shadow-lg hover:shadow-xl transition-all duration-150 hover:-translate-y-0.5"
          style="background: linear-gradient(135deg, oklch(0.62 0.20 145), oklch(0.52 0.20 145));"
        >
          <span>Start Exploring Free</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
        </a>
        <a
          href="#how-it-works"
          class="inline-flex items-center gap-2 px-8 py-4 rounded-xl font-bold text-base border-2 hover:shadow-md transition-all duration-150 hover:-translate-y-0.5"
          style="border-color: oklch(0.62 0.20 145); color: oklch(0.40 0.20 145); background: white;"
        >
          <span>See How It Works</span>
        </a>
      </div>

      <!-- Micro-proof -->
      <p class="mt-5 text-sm animate-slide-up delay-400" style="color: oklch(0.55 0.015 145);">
        Free to explore · No account needed to start · Loved by homeschool families
      </p>

      <!-- Hero stats pill row -->
      <div class="mt-12 flex flex-wrap items-center justify-center gap-6 animate-slide-up delay-400">
        <div class="flex items-center gap-2">
          <span class="text-2xl">🐾</span>
          <span class="text-sm font-semibold" style="color: oklch(0.30 0.018 145);">500+ Animals Covered</span>
        </div>
        <div class="w-px h-6 hidden sm:block" style="background: oklch(0.87 0.12 145);"></div>
        <div class="flex items-center gap-2">
          <span class="text-2xl">🌿</span>
          <span class="text-sm font-semibold" style="color: oklch(0.30 0.018 145);">Plants &amp; Ecosystems</span>
        </div>
        <div class="w-px h-6 hidden sm:block" style="background: oklch(0.87 0.12 145);"></div>
        <div class="flex items-center gap-2">
          <span class="text-2xl">🔬</span>
          <span class="text-sm font-semibold" style="color: oklch(0.30 0.018 145);">Real Science Facts</span>
        </div>
        <div class="w-px h-6 hidden sm:block" style="background: oklch(0.87 0.12 145);"></div>
        <div class="flex items-center gap-2">
          <span class="text-2xl">👧</span>
          <span class="text-sm font-semibold" style="color: oklch(0.30 0.018 145);">Ages 5–14</span>
        </div>
      </div>

    </div>
  </section>

  <!-- =====================================================================
       SOCIAL PROOF BAR — trusted by families
       ===================================================================== -->
  <section class="py-10 border-y" style="background: oklch(0.24 0.14 145); border-color: oklch(0.32 0.16 145);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6 text-center md:text-left">

        <p class="text-sm font-semibold uppercase tracking-widest" style="color: oklch(0.86 0.22 92);">
          Where Curious Kids Belong
        </p>

        <div class="flex flex-wrap justify-center md:justify-end gap-8">
          <div>
            <div class="text-3xl font-extrabold text-white font-display">500+</div>
            <div class="text-xs mt-0.5 font-medium" style="color: oklch(0.72 0.18 145);">Species & Plants</div>
          </div>
          <div>
            <div class="text-3xl font-extrabold text-white font-display">1,000+</div>
            <div class="text-xs mt-0.5 font-medium" style="color: oklch(0.72 0.18 145);">Science Facts</div>
          </div>
          <div>
            <div class="text-3xl font-extrabold text-white font-display">5–14</div>
            <div class="text-xs mt-0.5 font-medium" style="color: oklch(0.72 0.18 145);">Perfect Age Range</div>
          </div>
          <div>
            <div class="text-3xl font-extrabold text-white font-display">100%</div>
            <div class="text-xs mt-0.5 font-medium" style="color: oklch(0.72 0.18 145);">Kid-First Design</div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- =====================================================================
       FEATURES GRID — what makes Banana Slug Club different
       ===================================================================== -->
  <section id="explore" class="py-20 md:py-28 lg:py-32" style="background: oklch(0.99 0.003 145);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Section header -->
      <div class="text-center max-w-2xl mx-auto mb-14">
        <p class="text-sm font-bold uppercase tracking-widest mb-3" style="color: oklch(0.62 0.20 145);">Why Kids Love It</p>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight font-display" style="color: oklch(0.20 0.016 145);">
          A Nature Adventure Built for Real Kids
        </h2>
        <p class="mt-4 text-lg leading-relaxed" style="color: oklch(0.40 0.018 145);">
          Not a textbook. Not passive TV. Banana Slug Club is where kids who stop to look at bugs and ask "why?" finally find their place.
        </p>
      </div>

      <!-- 4-card grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">

        <!-- Card 1 -->
        <div class="rounded-2xl p-7 flex flex-col gap-4 border border-transparent hover:border-brand-200 hover:shadow-lg transition-all duration-200 animate-slide-up delay-100" style="background: oklch(0.96 0.008 145);">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center text-2xl" style="background: oklch(0.93 0.07 145);">🦁</div>
          <h3 class="text-lg font-bold font-display" style="color: oklch(0.20 0.016 145);">Animals from Every Corner</h3>
          <p class="text-sm leading-relaxed" style="color: oklch(0.44 0.018 145);">
            Dive into detailed guides on hundreds of animals — from ocean giants to backyard beetles. Each profile has photos, habits, diets, and surprising facts your kid won't find in a textbook.
          </p>
        </div>

        <!-- Card 2 -->
        <div class="rounded-2xl p-7 flex flex-col gap-4 border border-transparent hover:border-brand-200 hover:shadow-lg transition-all duration-200 animate-slide-up delay-200" style="background: oklch(0.96 0.008 145);">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center text-2xl" style="background: oklch(0.93 0.07 145);">🌱</div>
          <h3 class="text-lg font-bold font-display" style="color: oklch(0.20 0.016 145);">Plants &amp; Wild Habitats</h3>
          <p class="text-sm leading-relaxed" style="color: oklch(0.44 0.018 145);">
            From redwood forests to desert succulents — explore the plants that feed, shelter, and shape the natural world. Kids learn to recognize species they'll actually see outside.
          </p>
        </div>

        <!-- Card 3 -->
        <div class="rounded-2xl p-7 flex flex-col gap-4 border border-transparent hover:border-brand-200 hover:shadow-lg transition-all duration-200 animate-slide-up delay-300" style="background: oklch(0.96 0.008 145);">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center text-2xl" style="background: oklch(0.93 0.07 145);">🔭</div>
          <h3 class="text-lg font-bold font-display" style="color: oklch(0.20 0.016 145);">Science That Sparks Curiosity</h3>
          <p class="text-sm leading-relaxed" style="color: oklch(0.44 0.018 145);">
            Why do chameleons change color? How do Venus flytraps know when to snap shut? Banana Slug Club answers the questions curious kids actually ask — in plain, exciting language.
          </p>
        </div>

        <!-- Card 4 -->
        <div class="rounded-2xl p-7 flex flex-col gap-4 border border-transparent hover:border-brand-200 hover:shadow-lg transition-all duration-200 animate-slide-up delay-400" style="background: oklch(0.96 0.008 145);">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center text-2xl" style="background: oklch(0.93 0.07 145);">🏠</div>
          <h3 class="text-lg font-bold font-display" style="color: oklch(0.20 0.016 145);">Made for Homeschool Families</h3>
          <p class="text-sm leading-relaxed" style="color: oklch(0.44 0.018 145);">
            Parents trust Banana Slug Club as real supplemental learning — not mindless screen time. Built by a dad and his son, so it feels authentic, not corporate. Kids come back on their own.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- =====================================================================
       MASCOT SPOTLIGHT — the slug & brand story
       ===================================================================== -->
  <section class="py-20 md:py-28 overflow-hidden" style="background: linear-gradient(135deg, oklch(0.93 0.07 145) 0%, oklch(0.97 0.04 145) 100%);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

        <!-- Text side -->
        <div class="animate-slide-up">
          <p class="text-sm font-bold uppercase tracking-widest mb-3" style="color: oklch(0.52 0.20 145);">Our Story</p>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight font-display mb-5" style="color: oklch(0.20 0.016 145);">
            Why a Banana Slug?
          </h2>
          <p class="text-lg leading-relaxed mb-4" style="color: oklch(0.38 0.018 145);">
            Banana slugs are bright yellow, slippery, and absolutely fascinating — the perfect symbol for the kind of cool, overlooked nature most kids never learn about. This club is for kids who stop to <em>look</em>.
          </p>
          <p class="text-lg leading-relaxed mb-6" style="color: oklch(0.38 0.018 145);">
            Banana Slug Club started as a father and son's shared obsession with the natural world. We built the platform we wished existed — one where every creature, plant, and science question gets real respect and a real answer.
          </p>
          <a
            href="#explore"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-bold text-white text-sm transition-all duration-150 hover:shadow-md hover:-translate-y-0.5"
            style="background: linear-gradient(135deg, oklch(0.62 0.20 145), oklch(0.52 0.20 145));"
          >
            Explore the Club
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
          </a>
        </div>

        <!-- Visual side — big emoji collage -->
        <div class="relative flex items-center justify-center h-64 lg:h-80 animate-slide-up delay-200">
          <!-- Central slug -->
          <div class="absolute text-8xl md:text-9xl animate-wiggle select-none z-10" style="filter: drop-shadow(0 8px 24px oklch(0.62 0.20 145 / 0.3));" aria-hidden="true">🐌</div>
          <!-- Orbiting icons -->
          <div class="absolute top-2 left-12 text-4xl animate-float select-none" style="animation-delay: 0.2s;" aria-hidden="true">🦎</div>
          <div class="absolute top-4 right-10 text-4xl animate-float select-none" style="animation-delay: 0.8s;" aria-hidden="true">🌺</div>
          <div class="absolute bottom-4 left-8 text-4xl animate-float select-none" style="animation-delay: 0.4s;" aria-hidden="true">🐸</div>
          <div class="absolute bottom-2 right-12 text-4xl animate-float select-none" style="animation-delay: 1.0s;" aria-hidden="true">🍄</div>
          <div class="absolute top-1/2 -left-2 text-3xl animate-float select-none" style="animation-delay: 0.6s;" aria-hidden="true">🐝</div>
          <div class="absolute top-1/2 -right-2 text-3xl animate-float select-none" style="animation-delay: 1.4s;" aria-hidden="true">🦋</div>
          <!-- BG circle -->
          <div class="absolute w-56 h-56 rounded-full opacity-30" style="background: radial-gradient(circle, oklch(0.86 0.22 92 / 0.6), transparent 70%);"></div>
        </div>

      </div>
    </div>
  </section>

  <!-- =====================================================================
       HOW IT WORKS — 3 steps
       ===================================================================== -->
  <section id="how-it-works" class="py-20 md:py-28 lg:py-32" style="background: oklch(0.99 0.003 145);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="text-center max-w-xl mx-auto mb-14">
        <p class="text-sm font-bold uppercase tracking-widest mb-3" style="color: oklch(0.62 0.20 145);">Simple to Start</p>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight font-display" style="color: oklch(0.20 0.016 145);">
          Start Exploring in 3 Steps
        </h2>
      </div>

      <!-- Steps -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 relative">

        <!-- Connector line (desktop only) -->
        <div class="hidden md:block absolute top-10 left-1/3 right-1/3 h-0.5 opacity-30" style="background: linear-gradient(to right, oklch(0.62 0.20 145), oklch(0.86 0.22 92), oklch(0.62 0.20 145));"></div>

        <!-- Step 1 -->
        <div class="flex flex-col items-center text-center gap-4 animate-slide-up delay-100">
          <div class="relative">
            <div class="w-20 h-20 rounded-2xl flex items-center justify-center text-3xl shadow-md" style="background: linear-gradient(135deg, oklch(0.62 0.20 145), oklch(0.52 0.20 145));">
              🔍
            </div>
            <div class="absolute -top-2 -right-2 w-7 h-7 rounded-full flex items-center justify-center text-xs font-extrabold text-white" style="background: oklch(0.76 0.20 92);">1</div>
          </div>
          <h3 class="text-xl font-bold font-display" style="color: oklch(0.20 0.016 145);">Pick Something Curious</h3>
          <p class="text-base leading-relaxed max-w-xs" style="color: oklch(0.44 0.018 145);">
            Search any animal, plant, or science topic your kid is thinking about — or browse our curated collections by habitat, size, or ecosystem.
          </p>
        </div>

        <!-- Step 2 -->
        <div class="flex flex-col items-center text-center gap-4 animate-slide-up delay-200">
          <div class="relative">
            <div class="w-20 h-20 rounded-2xl flex items-center justify-center text-3xl shadow-md" style="background: linear-gradient(135deg, oklch(0.86 0.22 92), oklch(0.76 0.20 92));">
              📖
            </div>
            <div class="absolute -top-2 -right-2 w-7 h-7 rounded-full flex items-center justify-center text-xs font-extrabold text-white" style="background: oklch(0.62 0.20 145);">2</div>
          </div>
          <h3 class="text-xl font-bold font-display" style="color: oklch(0.20 0.016 145);">Dive Into the Full Story</h3>
          <p class="text-base leading-relaxed max-w-xs" style="color: oklch(0.44 0.018 145);">
            Every page is packed with vivid photos, surprising science facts, habitat maps, and kid-friendly explanations. No dry definitions — just real, exciting information.
          </p>
        </div>

        <!-- Step 3 -->
        <div class="flex flex-col items-center text-center gap-4 animate-slide-up delay-300">
          <div class="relative">
            <div class="w-20 h-20 rounded-2xl flex items-center justify-center text-3xl shadow-md" style="background: linear-gradient(135deg, oklch(0.62 0.20 145), oklch(0.40 0.18 145));">
              🌍
            </div>
            <div class="absolute -top-2 -right-2 w-7 h-7 rounded-full flex items-center justify-center text-xs font-extrabold text-white" style="background: oklch(0.86 0.22 92); color: oklch(0.24 0.14 145);">3</div>
          </div>
          <h3 class="text-xl font-bold font-display" style="color: oklch(0.20 0.016 145);">Keep Exploring the World</h3>
          <p class="text-base leading-relaxed max-w-xs" style="color: oklch(0.44 0.018 145);">
            One discovery leads to another. Related animals, linked habitats, and surprising science connections keep curious kids coming back — on their own, no prodding needed.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- =====================================================================
       TOPICS PREVIEW — nature categories
       ===================================================================== -->
  <section class="py-20 md:py-24" style="background: oklch(0.96 0.008 145);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="text-center max-w-xl mx-auto mb-10">
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight font-display" style="color: oklch(0.20 0.016 145);">
          What Will You Explore First?
        </h2>
        <p class="mt-3 text-base" style="color: oklch(0.44 0.018 145);">Every corner of the natural world — waiting to be discovered.</p>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4">
        {[
          { emoji: "🦅", label: "Birds" },
          { emoji: "🦈", label: "Ocean Life" },
          { emoji: "🐘", label: "Mammals" },
          { emoji: "🦎", label: "Reptiles" },
          { emoji: "🌵", label: "Plants" },
          { emoji: "🐛", label: "Insects" },
        ].map((topic, i) => (
          <div
            class={`rounded-xl p-5 flex flex-col items-center gap-3 border hover:shadow-md transition-all duration-200 cursor-pointer hover:-translate-y-1 animate-slide-up delay-${(i + 1) * 100}`}
            style="background: white; border-color: oklch(0.87 0.12 145);"
          >
            <span class="text-4xl">{topic.emoji}</span>
            <span class="text-sm font-bold" style="color: oklch(0.30 0.018 145);">{topic.label}</span>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- =====================================================================
       TESTIMONIAL / PARENT QUOTE
       ===================================================================== -->
  <section class="py-20 md:py-28" style="background: oklch(0.99 0.003 145);">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="text-5xl mb-6 animate-slide-up" aria-hidden="true">🌟</div>
      <blockquote class="text-2xl md:text-3xl font-bold leading-tight font-display mb-6 animate-slide-up delay-100" style="color: oklch(0.24 0.14 145);">
        "My 8-year-old asks to use Banana Slug Club. She spent an hour reading about tardigrades last week. That's what I call a win."
      </blockquote>
      <p class="text-base font-semibold animate-slide-up delay-200" style="color: oklch(0.62 0.20 145);">— Sarah M., homeschool parent of three</p>

      <!-- Star row -->
      <div class="flex justify-center gap-1 mt-4 animate-slide-up delay-300">
        {Array(5).fill(0).map(() => (
          <svg class="w-5 h-5" viewBox="0 0 20 20" fill="oklch(0.86 0.22 92)" aria-hidden="true">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
          </svg>
        ))}
      </div>
    </div>
  </section>

  <!-- =====================================================================
       FINAL CTA — full-width accent gradient, different angle
       ===================================================================== -->
  <section id="cta" class="py-20 md:py-28 relative overflow-hidden">

    <!-- Forest-sunrise gradient -->
    <div class="absolute inset-0" style="background: linear-gradient(135deg, oklch(0.24 0.14 145) 0%, oklch(0.40 0.18 145) 50%, oklch(0.52 0.20 145) 100%);"></div>
    <!-- Yellow glow overlay -->
    <div class="absolute top-0 right-0 w-96 h-96 rounded-full opacity-20" style="background: radial-gradient(circle, oklch(0.86 0.22 92), transparent 70%);"></div>
