---
<header class="sticky top-0 z-50 border-b" style="border-color: oklch(0.87 0.12 145); background: oklch(0.99 0.003 145 / 0.92); backdrop-filter: blur(12px);">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">

    <!-- Logo + wordmark -->
    <a href="/" class="flex items-center gap-2.5 group">
      <span class="text-2xl group-hover:animate-wiggle" aria-hidden="true">🐌</span>
      <span class="text-base font-extrabold tracking-tight font-display" style="color: oklch(0.24 0.14 145);">
        Banana Slug Club
      </span>
    </a>

    <!-- Nav links -->
    <div class="hidden md:flex items-center gap-7">
      <a href="#explore" class="text-sm font-medium transition-colors hover:text-brand-600" style="color: oklch(0.44 0.018 145);">Animals</a>
      <a href="#explore" class="text-sm font-medium transition-colors hover:text-brand-600" style="color: oklch(0.44 0.018 145);">Plants</a>
      <a href="#explore" class="text-sm font-medium transition-colors hover:text-brand-600" style="color: oklch(0.44 0.018 145);">Science</a>
      <a href="#how-it-works" class="text-sm font-medium transition-colors hover:text-brand-600" style="color: oklch(0.44 0.018 145);">For Families</a>
    </div>

    <!-- CTA -->
    <a
      href="https://www.bananaslugclub.com/"
      class="text-sm font-bold px-5 py-2 rounded-lg transition-all duration-150 hover:shadow-md hover:-translate-y-0.5"
      style="background: linear-gradient(135deg, oklch(0.62 0.20 145), oklch(0.52 0.20 145)); color: white;"
    >
      Start Exploring
    </a>

  </nav>
</header>
