---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Banana Slug Club — Explore Every Animal, Plant & Science Wonder",
  description = "From banana slugs to blue whales — discover the amazing natural world through interactive guides, vivid photos, and fun science facts built for kids ages 5–14."
} = Astro.props;
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <title>{title}</title>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Banana Slug Club",
      "description": "Kids nature and science education platform — animals, plants, and science for curious kids ages 5–14.",
      "url": "https://banana-slug-club.onrender.com"
    }
    </script>
  </head>
  <body class="min-h-screen flex flex-col antialiased" style="background: oklch(0.99 0.003 145); color: oklch(0.20 0.016 145); font-family: 'Space Grotesk', ui-sans-serif, system-ui, sans-serif;">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
