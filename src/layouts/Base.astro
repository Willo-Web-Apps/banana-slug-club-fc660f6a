---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = "Your New Business", description = "let's make an amazing platform for kids to study and learn all about nature, animals, plants, and science. Bold green and yellow color theme for the website and very friendly for kids. This is going to be a v2 of our current platform Banana Slug Club. So you can just name it Banana Slug Club and you can get more info here on our old website. https://www.bananaslugclub.com/" } = Astro.props;
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <title>{title}</title>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Your New Business",
      "description": "let's make an amazing platform for kids to study and learn all about nature, animals, plants, and science. Bold green and yellow color theme for the website and very friendly for kids. This is going to be a v2 of our current platform Banana Slug Club. So you can just name it Banana Slug Club and you can get more info here on our old website. https://www.bananaslugclub.com/",
      "url": "https://banana-slug-club.onrender.com"
    }
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-surface-50 text-surface-900 font-body antialiased">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
